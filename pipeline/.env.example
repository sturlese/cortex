# ============================================================================
#  cortex ingestion stack — environment. Copy to `.env` and fill in.
#  NEVER commit `.env`:    cp .env.example .env
#
#  Used by `fetch` (env_file) and by docker compose to interpolate ${VARS}.
#  LEAST PRIVILEGE: this stack carries NO DATABASE_URL and nothing from the
#  brain server. It looks outward (Drive + LLM APIs) but never at the database.
# ============================================================================

# ── Drive (gog) — used by fetch ──────────────────────────────────────────────
# gog stores its config + OAuth token under GOG_HOME, in a file keyring protected
# by this password. GOG_HOME -> gog-state volume (persistent).
GOG_HOME=/data/gog
GOG_KEYRING_BACKEND=file
GOG_KEYRING_PASSWORD=
# The Drive OAuth client_secret is configured with `gog auth add ... --services drive`
# (it lives inside the gog-state volume). NEVER put it in git.
GOG_ACCOUNT=
# ROOT folder to mirror, by NAME (the script resolves the id). REQUIRED:
DRIVE_FOLDER=
# DRIVE_FOLDER_ID=              # alternative: explicit id (when the name is ambiguous)
GOG_ALL_DRIVES=true             # include shared drives in the search/inventory
POLL_INTERVAL_SECONDS=1800      # sync cadence (1800=30min, 3600=1h, 300=5min)
GOOGLE_DOCS_FORMAT=md           # export format for native Google Docs (pdf|docx|md|txt|...)
# RAW_DIR=/data/raw             # (default) the mirror; same path as the raw-drive volume

# ── clean (PydanticAI + OpenAI Responses API) ────────────────────────────────
OPENAI_API_KEY=                 # REQUIRED to process. Set a hard spend cap in the OpenAI dashboard.
# Knobs (defaults live in docker-compose.yml):
# CLEAN_DRY_RUN=true            # true = safe no-op loop; false = actually process
# CLEAN_INTERVAL_SECONDS=300    # loop cadence
# CLEAN_MAX_DOCS=0              # 0 = unlimited; >0 = bounded trial (N docs)
# CLEAN_MAX_CONCURRENT=4        # docs in parallel (asyncio)
# CLEAN_MODEL=gpt-5.4           # processor model
# CLEAN_REASONING_EFFORT=medium # minimal|low|medium|high
# CLEAN_TOKEN_BUDGET=0          # hard per-pass token ceiling (0 = uncapped)
# CLEAN_PLAYBOOK=on             # off = ignore the supervisor-distilled playbook
# CLEAN_TRACE=                  # 'logfire' = OTel tracing of agent runs (pip install logfire)

# ── ocr tool (optional) ──────────────────────────────────────────────────────
# Lets the clean agent re-read scanned/visual PDFs with a vision model when the
# deterministic extraction comes out mangled. Without a key the tool degrades
# gracefully (such pages are flagged extraction_quality: manual_review).
GEMINI_API_KEY=
# VISION_MODEL=gemini-3-flash-preview
