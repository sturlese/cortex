{
  "_comment": "Curation taxonomy: ORDERED rules, first match wins. Each rule assigns a doc type and a verdict (IN = index, MAYBE = keep for review, OUT = discard). Matching is case- and accent-insensitive. Matchers within a rule: 'ext' (file extension), 'basename_any' (substrings of the file name), 'path_any' (substrings anywhere in the path), 'path_regex' (regexes over the path); ANY matcher hit triggers the rule — use path_regex when you need AND semantics. This file is an EXAMPLE for a generic company drive: tune it to yours. The engine lives in stages/classify_files.py. 'org_units' optionally maps top-level folder names to short labels (unmapped folders use their own name). 'demoted_types' are dropped by trim-manifest.",
  "org_units": {},
  "demoted_types": ["other", "internal-admin"],
  "fallback": { "type": "other", "verdict": "MAYBE" },
  "rules": [
    { "type": "system-noise", "verdict": "OUT",
      "ext": [".ds_store", ".ini", ".tmp", ".lnk", ".url", ".localized", ".download", ".crdownload"] },
    { "type": "web-assets", "verdict": "OUT",
      "ext": [".js", ".css", ".scss", ".map", ".ttf", ".woff", ".woff2", ".eot"] },

    { "type": "meeting-minutes", "verdict": "IN",
      "basename_any": ["minutes", "meeting notes"],
      "path_any": ["board meeting", "committee", "all hands", "offsite"] },
    { "type": "reports", "verdict": "IN",
      "path_any": ["quarterly report", "monthly report", "annual report", "status report",
                   "kpi", "metrics", "dashboard", "progress update"] },
    { "type": "presentations", "verdict": "IN",
      "basename_any": ["deck", "pitch", "presentation", "teaser", "one pager", "one-pager"] },
    { "type": "product-docs", "verdict": "IN",
      "path_any": ["prd", "roadmap", "design doc", "architecture", "rfc", "postmortem"],
      "path_regex": ["\\bspec"] },
    { "type": "strategy", "verdict": "IN",
      "path_any": ["strategy", "okr", "planning", "market map", "competitive analysis"] },
    { "type": "memos", "verdict": "IN",
      "basename_any": ["memo", "proposal", "brief"] },
    { "type": "data-room", "verdict": "MAYBE",
      "path_any": ["data room", "dataroom", "due diligence"] },
    { "type": "research", "verdict": "MAYBE",
      "path_any": ["research", "benchmark", "whitepaper", "training"] },

    { "type": "legal-contracts", "verdict": "OUT",
      "path_any": ["contract", "agreement", "terms of service", "bylaws", "deed",
                   "power of attorney", "notarial", "articles of incorporation"],
      "path_regex": ["\\bnda"] },
    { "type": "finance-accounting", "verdict": "OUT",
      "path_any": ["invoice", "payroll", "accounting", "financial statements", "bookkeeping",
                   "expense", "receipts", "audit", "ledger"] },
    { "type": "tax", "verdict": "OUT",
      "path_any": ["tax filing", "vat return", "withholding"] },
    { "type": "hr", "verdict": "OUT",
      "path_any": ["recruiting", "resume", "onboarding", "offboarding", "performance review",
                   "employment", "payslip"] },
    { "type": "compliance", "verdict": "OUT",
      "path_any": ["kyc", "aml", "gdpr", "data protection", "compliance"] },
    { "type": "marketing-media", "verdict": "OUT",
      "path_any": ["press", "logo", "brand assets", "photos", "social media"] },
    { "type": "internal-admin", "verdict": "OUT",
      "path_any": ["office supplies", "travel booking", "catering", "facilities", "it support"] }
  ]
}
