# ============================================================================
#  gbrain deploy — environment. Copy to `.env` and fill in. NEVER commit `.env`.
#    cp .env.example .env
# ============================================================================

# ── gbrain version (reproducibility) ───────────────────────────────────────
# Full commit SHA of garrytan/gbrain to build. Immutable. = v0.42.34.0.
# Bump this + `make up` to upgrade gbrain (schema migrations run automatically).
GBRAIN_REF=099d9a8f5505f1d64e4f4f784f8429cc2d47c18f
BUN_VERSION=1.3.10

# ── Supabase (Postgres) ─────────────────────────────────────────────────────
# Use the TRANSACTION POOLER string (port 6543), NOT the direct 5432 connection.
# Supabase dashboard → Connect → "Transaction pooler".
DATABASE_URL=postgresql://postgres.PROJECTREF:YOUR_DB_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres

# DDL/migrations need a SESSION connection (the transaction pooler can't run
# CREATE INDEX CONCURRENTLY). gbrain auto-derives `db.<ref>.supabase.co:5432` —
# but that direct host is IPv6-ONLY, and most VMs (Hetzner included) can't reach
# it, so first boot fails with `ECONNREFUSED <ipv6>:5432` and migrations never
# run. Fix: point this at the Supabase SESSION POOLER = the SAME pooler host on
# port 5432 (IPv4-compatible). Just take DATABASE_URL above and swap 6543 → 5432.
# See docs/RUNBOOK.md (Gotcha 1).
GBRAIN_DIRECT_DATABASE_URL=postgresql://postgres.PROJECTREF:YOUR_DB_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# ── Embeddings: OpenAI text-embedding-3-small, 1536d — cheapest + HARD spend cap ─
# Fixes the vector(N) column on first boot. Changing the model later → full reindex.
# OpenAI lets you set a hard monthly budget: platform.openai.com → Settings → Limits.
GBRAIN_EMBEDDING_MODEL=openai:text-embedding-3-small
GBRAIN_EMBEDDING_DIMENSIONS=1536
OPENAI_API_KEY=sk-...
# Alternatives (pick ONE; set its key; the dims fix the column at first boot):
#   openai:text-embedding-3-large  → 1536d, $0.13/M  (better quality, also capped)
#   voyage:voyage-3                → 1024d, $0.06/M  (set VOYAGE_API_KEY=...)
#   zeroentropyai:zembed-1         → 1280d, $0.05/M  (no spend cap; set ZEROENTROPY_API_KEY=...)

# ── Chat / synthesis: Anthropic ─────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# Optional override (default is a current Sonnet):
# GBRAIN_CHAT_MODEL=anthropic:claude-sonnet-4-6

# ── HTTP server / reverse-proxy ─────────────────────────────────────────────
# Public Funnel URL = https://<TS_HOSTNAME>.<your-tailnet>.ts.net
# Find <your-tailnet> in the Tailscale admin console (top-left, e.g. tail1234.ts.net).
# With TS_HOSTNAME=gbrain it becomes https://gbrain.tail1234.ts.net
GBRAIN_PUBLIC_URL=https://gbrain.YOUR-TAILNET.ts.net

# Trust X-Forwarded-* from the Tailscale Funnel sidecar (1 hop) → real client IP + Secure cookies.
GBRAIN_HTTP_TRUST_PROXY=1

# Stable admin token for the /admin dashboard. MUST be >= 32 chars, [A-Za-z0-9_-].
# Generate one:  head -c 32 /dev/urandom | base64 | tr -d '+/=' | head -c 48
GBRAIN_ADMIN_BOOTSTRAP_TOKEN=

# Only if a BROWSER-based MCP client needs CORS (comma-separated origins), e.g. https://claude.ai
# GBRAIN_HTTP_CORS_ORIGIN=

# State dir inside the container (mapped to the gbrain-data volume). Leave as-is.
GBRAIN_HOME=/data

# ── Tailscale ───────────────────────────────────────────────────────────────
# Reusable auth key from the Tailscale admin console → Settings → Keys.
# Recommended: Reusable + Ephemeral OFF (so the node keeps its identity across restarts).
TS_AUTHKEY=tskey-auth-...
# Node name. The public host becomes <TS_HOSTNAME>.<your-tailnet>.ts.net
TS_HOSTNAME=gbrain

# ── ingest (optional; profile "ingest") ─────────────────────────────────────
# Source name the corpus is registered/synced under, and the loop cadence.
GBRAIN_SYNC_SOURCE=brain
GBRAIN_SYNC_INTERVAL=1800
# Which layer to index: the raw pages, or the graphed layer (wikilinks + entity
# nodes) if you run the pipeline's graph stage.
GBRAIN_SYNC_PATH=/data/brain-md
# GBRAIN_SYNC_PATH=/data/brain-md-graphed
